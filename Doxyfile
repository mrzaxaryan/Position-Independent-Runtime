# =============================================================================
# Doxyfile - Position-Independent Runtime
# =============================================================================

PROJECT_NAME           = "Position-Independent Runtime"
PROJECT_BRIEF          = "Position-Independent Runtime for Windows, Linux, and UEFI"
OUTPUT_DIRECTORY       = docs

# -----------------------------------------------------------------------------
# Input
# -----------------------------------------------------------------------------
INPUT                  = src/core src/platform src/runtime
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cc *.cpp

# -----------------------------------------------------------------------------
# Extraction
# -----------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES

# -----------------------------------------------------------------------------
# Source browsing
# -----------------------------------------------------------------------------
SOURCE_BROWSER         = YES

# -----------------------------------------------------------------------------
# Output formats
# -----------------------------------------------------------------------------
GENERATE_HTML          = YES
GENERATE_LATEX         = NO

# -----------------------------------------------------------------------------
# Diagrams (Graphviz)
# -----------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
